## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# Build results
bin/
obj/
out/

# User-specific files
*.user
*.suo
*.userosscache
*.sln.docstates

# OS generated files
.DS_Store
Thumbs.db

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# Dotnet watch
**/node_modules/
**/bower_components/

# Visual Studio Code
.vscode/

# NuGet packages
*.nupkg
# The packages folder can be ignored because of Package Restore
**/packages/*
!**/packages/build/
!**/packages/repositories.config

# Others
*.log
*.vspscc
*.vssscc
*.pdb

# Rider
.idea/
*.json
# Local test results
TestResults/
*.coverage
*.coveragexml

# Publish output
publish/